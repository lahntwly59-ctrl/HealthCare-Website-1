@{
    ViewData["Title"] = "Change Password";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div style="max-width:440px; margin:0 auto;">
    <div class="card">
        <div class="card-title"><i class="fas fa-lock"></i> Change Password</div>

        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger"><i class="fas fa-exclamation-triangle"></i> @TempData["Error"]</div>
        }

        <form method="post" asp-action="ChangePassword" asp-controller="Account">
            @Html.AntiForgeryToken()
            <div class="form-group">
                <label class="form-label">Current Password</label>
                <input name="CurrentPassword" type="password" class="form-control" required />
            </div>
            <div class="form-group">
                <label class="form-label">New Password</label>
                <input name="NewPassword" type="password" class="form-control" required />
            </div>
            <div class="form-group">
                <label class="form-label">Confirm New Password</label>
                <input name="ConfirmNewPassword" type="password" class="form-control" required />
            </div>
            <div style="display:flex; gap:10px; margin-top:8px;">
                <button type="submit" class="btn btn-primary">
                    <i class="fas fa-save"></i> Save Password
                </button>
                <a href="/Account/Profile" class="btn btn-outline">Cancel</a>
            </div>
        </form>
    </div>
</div>
