@model HealthCareApp.Models.Entities.Patient
@{
    ViewData["Title"] = "My Profile";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div style="max-width:640px; margin:0 auto;">
    <div class="card">
        @* Header *@
        <div style="display:flex; align-items:center; gap:20px; margin-bottom:28px; padding-bottom:20px; border-bottom:1px solid var(--border);">
            <div style="width:72px; height:72px; border-radius:50%; background:linear-gradient(135deg,var(--primary),var(--accent)); display:flex; align-items:center; justify-content:center; font-size:1.6rem; font-weight:800; color:#fff;">
                @(Model.FirstName[0])@(Model.LastName[0])
            </div>
            <div>
                <div style="font-size:1.3rem; font-weight:800;">@Model.FullName</div>
                <div style="font-size:.82rem; color:var(--muted); margin-top:2px;">Patient ID: #@Model.Patient_ID</div>
                <span style="font-size:.75rem; background:rgba(39,174,96,.1); color:var(--success); padding:2px 10px; border-radius:20px; font-weight:600; margin-top:4px; display:inline-block;">Active</span>
            </div>
            <div style="margin-left:auto; display:flex; gap:8px;">
                <a href="/Account/ChangePassword" class="btn btn-outline btn-sm">
                    <i class="fas fa-lock"></i> Password
                </a>
            </div>
        </div>

        @* Fields *@
        <div style="display:grid; grid-template-columns:1fr 1fr; gap:16px;">
            @{
                void Field(string label, string? val, string icon)
                {
                    <div style="padding:14px; background:var(--bg); border-radius:8px;">
                        <div style="font-size:.7rem; color:var(--muted); font-weight:700; text-transform:uppercase; letter-spacing:.8px; margin-bottom:4px;">
                            <i class="fas fa-@icon" style="margin-right:5px;"></i>@label
                        </div>
                        <div style="font-size:.9rem; font-weight:600; color:var(--text);">@(string.IsNullOrEmpty(val) ? "—" : val)</div>
                    </div>
                }
            }
            @{
                Field("First Name", Model.FirstName, "user");
            }
            @{
                Field("Last Name", Model.LastName, "user");
            }
            @{
                Field("Email", Model.Email, "envelope");
            }
            @{
                Field("Phone", Model.Phone, "phone");
            }
            @{
                Field("Gender", Model.Gender == "M" ? "Male" : "Female", "venus-mars");
            }
            @{
                Field("Date of Birth", Model.Date_Of_Birth?.ToString("MMMM dd, yyyy") ?? "—", "birthday-cake");
            }
            @{
                Field("Address", Model.Address ?? "—", "map-marker-alt");
            }
        </div>
    </div>
</div>
