@model HealthCareApp.Models.ViewModels.LoginViewModel
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Sign In";
}

<div class="auth-page">
    <div class="auth-left">
        <h1>Your Health,<br />Our Priority</h1>
        <p>Access your appointments, connect with doctors, and manage your healthcare — all in one place.</p>
        <div class="auth-features">
            <div class="auth-feature"><i class="fas fa-calendar-check"></i> Book &amp; track appointments</div>
            <div class="auth-feature"><i class="fas fa-user-md"></i> Browse specialist doctors</div>
            <div class="auth-feature"><i class="fas fa-shield-alt"></i> Secure &amp; private records</div>
        </div>
    </div>
    <div class="auth-right">
        <div class="auth-box">
            <div class="auth-logo">
                <i class="fas fa-heartbeat"></i>
                <span>HealthCare</span>
            </div>
            <div class="auth-title">Welcome back</div>
            <div class="auth-sub">Sign in to your patient account</div>

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert alert-danger">
                    <i class="fas fa-exclamation-circle"></i>
                    @Html.ValidationSummary(true)
                </div>
            }

            <form method="post" asp-action="Login" asp-controller="Account">
                @Html.AntiForgeryToken()
                <div class="form-group">
                    <label class="form-label">Email Address</label>
                    <input name="Email" type="email" class="form-control" value="@Model?.Email" />
                    <span class="field-error">@Html.ValidationMessage("Email")</span>
                </div>
                <div class="form-group">
                    <label class="form-label">Password</label>
                    <input name="Password" type="password" class="form-control" placeholder="••••••••" autocomplete="current-password" />
                    <span class="field-error">@Html.ValidationMessage("Password")</span>
                </div>
                <button type="submit" class="btn btn-primary" style="width:100%; justify-content:center; padding:12px;">
                    <i class="fas fa-sign-in-alt"></i> Sign In
                </button>
            </form>

            <p style="margin-top:22px; text-align:center; font-size:.85rem; color:var(--muted);">
                Don't have an account?
                <a asp-action="Register" asp-controller="Account" class="auth-link">Create one</a>
            </p>
        </div>
    </div>
</div>