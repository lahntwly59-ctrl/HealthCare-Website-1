@model HealthCareApp.Models.ViewModels.RegisterViewModel
@{
    Layout = "~/Views/Shared/_Layout.cshtml"; ViewData["Title"] = "Register";
}

<div class="auth-page">
    <div class="auth-left">
        <h1>Join Our<br />Healthcare Network</h1>
        <p>Create your free patient account and start managing your health journey today.</p>
        <div class="auth-features">
            <div class="auth-feature"><i class="fas fa-calendar-check"></i> Book appointments instantly</div>
            <div class="auth-feature"><i class="fas fa-user-md"></i> Access top specialists</div>
            <div class="auth-feature"><i class="fas fa-history"></i> Track your health history</div>
        </div>
    </div>
    <div class="auth-right" style="width:520px; overflow-y:auto; padding:36px 48px;">
        <div class="auth-box">
            <div class="auth-logo">
                <i class="fas fa-heartbeat"></i>
                <span>HealthCare</span>
            </div>
            <div class="auth-title">Create account</div>
            <div class="auth-sub">Fill in your details to get started</div>

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert alert-danger">
                    <i class="fas fa-exclamation-circle"></i>
                    @Html.ValidationSummary(true)
                </div>
            }

            <form method="post" asp-action="Register" asp-controller="Account">
                @Html.AntiForgeryToken()

                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">First Name</label>
                        <input asp-for="FirstName" class="form-control" placeholder="John" />
                        <span asp-validation-for="FirstName" class="field-error"></span>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Last Name</label>
                        <input asp-for="LastName" class="form-control" placeholder="Doe" />
                        <span asp-validation-for="LastName" class="field-error"></span>
                    </div>
                </div>

                <div class="form-group">
                    <label class="form-label">Email Address</label>
                    <input asp-for="Email" class="form-control" placeholder="you@email.com" />
                    <span asp-validation-for="Email" class="field-error"></span>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">Password</label>
                        <input asp-for="Password" class="form-control" placeholder="Min. 6 characters" />
                        <span asp-validation-for="Password" class="field-error"></span>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Confirm Password</label>
                        <input asp-for="ConfirmPassword" class="form-control" placeholder="Repeat password" />
                        <span asp-validation-for="ConfirmPassword" class="field-error"></span>
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">Phone</label>
                        <input asp-for="Phone" class="form-control" placeholder="05xxxxxxxx" />
                        <span asp-validation-for="Phone" class="field-error"></span>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Gender</label>
                        <select asp-for="Gender" class="form-control form-select">
                            <option value="M">Male</option>
                            <option value="F">Female</option>
                        </select>
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">Date of Birth</label>
                        <input asp-for="Date_Of_Birth" type="date" class="form-control" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Address <span style="color:var(--muted)">(optional)</span></label>
                        <input asp-for="Address" class="form-control" placeholder="City, Street" />
                    </div>
                </div>

                <button type="submit" class="btn btn-primary" style="width:100%; justify-content:center; padding:12px;">
                    <i class="fas fa-user-plus"></i> Create Account
                </button>
            </form>

            <p style="margin-top:18px; text-align:center; font-size:.85rem; color:var(--muted);">
                Already have an account?
                <a asp-action="Login" asp-controller="Account" class="auth-link">Sign in</a>
            </p>
        </div>
    </div>
</div>