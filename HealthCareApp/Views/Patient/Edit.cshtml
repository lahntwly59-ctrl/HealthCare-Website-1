@model HealthCareApp.Models.Entities.Patient
@{
    Layout = "~/Views/Shared/_Layout.cshtml"; ViewData["Title"] = "Edit Profile";
}

<div style="max-width:600px; margin:0 auto;">
    <div class="card">
        <div class="card-title"><i class="fas fa-user-edit"></i> Edit Profile</div>

        <form method="post" asp-action="Edit" asp-controller="Patient">
            @Html.AntiForgeryToken()
            <div class="form-row">
                <div class="form-group">
                    <label class="form-label">First Name</label>
                    <input asp-for="FirstName" class="form-control" />
                    <span asp-validation-for="FirstName" class="field-error"></span>
                </div>
                <div class="form-group">
                    <label class="form-label">Last Name</label>
                    <input asp-for="LastName" class="form-control" />
                    <span asp-validation-for="LastName" class="field-error"></span>
                </div>
            </div>
            <div class="form-row">
                <div class="form-group">
                    <label class="form-label">Phone</label>
                    <input asp-for="Phone" class="form-control" />
                    <span asp-validation-for="Phone" class="field-error"></span>
                </div>
                <div class="form-group">
                    <label class="form-label">Gender</label>
                    <select asp-for="Gender" class="form-control form-select">
                        <option value="M">Male</option>
                        <option value="F">Female</option>
                    </select>
                </div>
            </div>
            <div class="form-row">
                <div class="form-group">
                    <label class="form-label">Date of Birth</label>
                    <input asp-for="Date_Of_Birth" type="date" class="form-control" />
                </div>
                <div class="form-group">
                    <label class="form-label">Address</label>
                    <input asp-for="Address" class="form-control" placeholder="City, Street" />
                </div>
            </div>
            <div style="display:flex; gap:10px; margin-top:8px;">
                <button type="submit" class="btn btn-primary"><i class="fas fa-save"></i> Save Changes</button>
                <a asp-action="Profile" asp-controller="Patient" class="btn btn-outline">Cancel</a>
            </div>
        </form>
    </div>
</div>