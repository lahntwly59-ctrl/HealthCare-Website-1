@model HealthCareApp.Models.Entities.Doctor
@{
    Layout = "~/Views/Shared/_Layout.cshtml"; ViewData["Title"] = "Delete Doctor";
}

<div style="max-width:480px; margin:0 auto;">
    <div class="card">
        <div style="text-align:center; padding:16px 0 24px;">
            <div style="width:64px; height:64px; border-radius:50%; background:rgba(224,82,82,.1); display:flex; align-items:center; justify-content:center; margin:0 auto 16px; font-size:1.6rem; color:#dc3545;">
                <i class="bi bi-trash"></i>
            </div>
            <div style="font-size:1.1rem; font-weight:800; margin-bottom:8px;">Delete Doctor?</div>
            <div style="color:#64748b; font-size:.88rem;">
                You are about to permanently delete
                <strong>Dr. @Model.FirstName @Model.LastName</strong>.
                This will also remove all their appointments. This action cannot be undone.
            </div>
        </div>

        <div style="background:#f8fafc; border-radius:8px; padding:14px; margin-bottom:20px;">
            <div style="font-size:.78rem; color:#64748b; margin-bottom:4px; font-weight:700;">DOCTOR</div>
            <div style="font-weight:700;">Dr. @Model.FirstName @Model.LastName — @Model.Field</div>
            <div style="font-size:.82rem; color:#64748b;">@Model.Department?.Department_Name</div>
        </div>

        <div class="d-flex gap-2">
            <form method="post" asp-action="Delete" asp-controller="Doctor"
                  asp-route-id="@Model.Doctor_ID" style="flex:1;">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-danger w-100">
                    <i class="bi bi-trash me-1"></i> Yes, Delete
                </button>
            </form>
            <a asp-action="Index" asp-controller="Doctor"
               class="btn btn-outline-secondary flex-fill text-center d-flex align-items-center justify-content-center">
                Cancel
            </a>
        </div>
    </div>
</div>
