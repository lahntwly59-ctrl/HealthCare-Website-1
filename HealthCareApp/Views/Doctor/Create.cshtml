@model HealthCareApp.Models.Entities.Doctor
@{
    Layout = "~/Views/Shared/_Layout.cshtml"; ViewData["Title"] = "Add Doctor";
}
<div style="max-width:600px; margin:0 auto;">
    <div class="card">
        <div class="card-title"><i class="fas fa-user-md"></i> Add New Doctor</div>
        <form method="post" asp-action="Create" asp-controller="Doctor">
            @Html.AntiForgeryToken()
            <div class="form-row">
                <div class="form-group">
                    <label class="form-label">First Name</label>
                    <input name="FirstName" class="form-control" placeholder="Omar" />
                    <span class="field-error">@Html.ValidationMessage("FirstName")</span>
                </div>
                <div class="form-group">
                    <label class="form-label">Last Name</label>
                    <input name="LastName" class="form-control" placeholder="Zaid" />
                    <span class="field-error">@Html.ValidationMessage("LastName")</span>
                </div>
            </div>
            <div class="form-row">
                <div class="form-group">
                    <label class="form-label">Specialization Field</label>
                    <select name="Field" class="form-control form-select" required>
                        <option value="">— Select Specialization —</option>
                        <option>Cardiology</option>
                        <option>Neurology</option>
                        <option>Orthopedics</option>
                        <option>Pediatrics</option>
                        <option>Dermatology</option>
                        <option>General Surgery</option>
                        <option>Emergency Medicine</option>
                        <option>Ophthalmology</option>
                        <option>Gynecology</option>
                        <option>Psychiatry</option>
                        <option>Radiology</option>
                        <option>Oncology</option>
                        <option>Urology</option>
                        <option>ENT</option>
                        <option>General Medicine</option>
                    </select>
                    <span class="field-error">@Html.ValidationMessage("Field")</span>
                </div>
                <div class="form-group">
                    <label class="form-label">Department</label>
                    <select name="Department_ID" class="form-control form-select" required>
                        <option value="">— Select —</option>
                        @foreach (var dept in (List<HealthCareApp.Models.Entities.Department>)ViewBag.Departments)
                        {
                            <option value="@dept.Department_ID">@dept.Department_Name</option>
                        }
                    </select>
                    <span class="field-error">@Html.ValidationMessage("Department_ID")</span>
                </div>
            </div>
            <div class="form-row">
                <div class="form-group">
                    <label class="form-label">Phone</label>
                    <input name="Phone" class="form-control" placeholder="05xxxxxxxx" />
                    <span class="field-error">@Html.ValidationMessage("Phone")</span>
                </div>
                <div class="form-group">
                    <label class="form-label">Email</label>
                    <input name="Email" type="email" class="form-control" placeholder="dr.name@hospital.com" />
                    <span class="field-error">@Html.ValidationMessage("Email")</span>
                </div>
            </div>
            <div style="display:flex; gap:10px; margin-top:8px;">
                <button type="submit" class="btn btn-primary"><i class="fas fa-save"></i> Add Doctor</button>
                <a asp-action="Index" class="btn btn-outline">Cancel</a>
            </div>
        </form>
    </div>
</div>
