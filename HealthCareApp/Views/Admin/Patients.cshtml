@model IEnumerable<HealthCareApp.Models.Entities.Patient>
@{
    ViewData["Title"] = "All Patients";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:20px;">
    <div></div>
    <form method="get" asp-action="Patients" asp-controller="Admin" style="display:flex; gap:8px;">
        <div class="search-bar">
            <i class="fas fa-search"></i>
            <input name="search" type="text" class="form-control" placeholder="Search by name or email..." value="@ViewBag.Search" style="width:280px;" />
        </div>
        <button type="submit" class="btn btn-primary"><i class="fas fa-search"></i></button>
        @if (!string.IsNullOrEmpty(ViewBag.Search as string))
        {
            <a href="/Admin/Patients" class="btn btn-outline">Clear</a>
        }
    </form>
</div>

@if (!Model.Any())
{
    <div class="card" style="text-align:center; padding:48px;">
        <i class="fas fa-users" style="font-size:2.5rem; color:var(--border); margin-bottom:12px;"></i>
        <div style="font-weight:700;">No patients found.</div>
    </div>
}
else
{
    <div class="card">
        <div class="table-wrap">
            <table>
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Phone</th>
                        <th>Gender</th>
                        <th>Role</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var p in Model)
                    {
                        bool isAdminUser = p.Address == "ADMIN" || p.Email == "lahntwly59@gmail.com";
                        <tr>
                            <td style="color:var(--muted); font-size:.8rem;">@p.Patient_ID</td>
                            <td style="font-weight:600;">@p.FullName</td>
                            <td style="font-size:.82rem;">@p.Email</td>
                            <td style="font-size:.82rem;">@p.Phone</td>
                            <td style="font-size:.82rem;">@(p.Gender == "M" ? "Male" : "Female")</td>
                            <td>
                                @if (isAdminUser)
                                {
                                    <span class="role-admin">Admin</span>
                                }
                                else
                                {
                                    <span class="role-patient">Patient</span>
                                }
                            </td>
                            <td>
                                @if (!isAdminUser)
                                {
                                    <form method="post" asp-action="DeletePatient" asp-controller="Admin" style="display:inline;">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@p.Patient_ID" />
                                        <button type="submit" class="btn btn-danger btn-sm"
                                                onclick="return confirm('Delete @p.FullName?')">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </form>
                                }
                                else
                                {
                                    <span style="color:var(--muted); font-size:.78rem;">Protected</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
