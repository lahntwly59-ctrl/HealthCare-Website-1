@{
    ViewData["Title"] = "Book Appointment";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div style="max-width:560px; margin:0 auto;">
    <div class="card">
        <div class="card-title"><i class="fas fa-calendar-plus"></i> Book Appointment</div>
        <form method="post" asp-action="BookAppointment" asp-controller="Admin">
            @Html.AntiForgeryToken()

            <div class="form-group">
                <label class="form-label">Patient</label>
                <select name="Patient_ID" class="form-control form-select" required>
                    <option value="">-- Select Patient --</option>
                    @foreach (var p in (List<HealthCareApp.Models.Entities.Patient>)ViewBag.Patients)
                    {
                        <option value="@p.Patient_ID">@p.FullName — @p.Email</option>
                    }
                </select>
            </div>

            <div class="form-group">
                <label class="form-label">Doctor</label>
                <select name="Doctor_ID" class="form-control form-select" required>
                    <option value="">-- Select Doctor --</option>
                    @foreach (var doc in (List<HealthCareApp.Models.Entities.Doctor>)ViewBag.Doctors)
                    {
                        <option value="@doc.Doctor_ID">Dr. @doc.FirstName @doc.LastName — @doc.Field (@doc.Department?.Department_Name)</option>
                    }
                </select>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label class="form-label">Date</label>
                    <input name="AppointmentDateOnly" type="date" class="form-control" min="@ViewBag.TodayMin" required />
                </div>
                <div class="form-group">
                    <label class="form-label">Time Slot</label>
                    <select name="AppointmentTimeSlot" class="form-control form-select" required>
                        <option value="">-- Time --</option>
                        <optgroup label="Morning">
                            <option value="08:00">8:00 AM</option>
                            <option value="09:00">9:00 AM</option>
                            <option value="10:00">10:00 AM</option>
                            <option value="11:00">11:00 AM</option>
                        </optgroup>
                        <optgroup label="Afternoon">
                            <option value="13:00">1:00 PM</option>
                            <option value="14:00">2:00 PM</option>
                            <option value="15:00">3:00 PM</option>
                            <option value="16:00">4:00 PM</option>
                        </optgroup>
                        <optgroup label="Evening">
                            <option value="17:00">5:00 PM</option>
                            <option value="18:00">6:00 PM</option>
                            <option value="19:00">7:00 PM</option>
                            <option value="20:00">8:00 PM</option>
                        </optgroup>
                    </select>
                </div>
            </div>

            <div class="form-group">
                <label class="form-label">Description <span style="color:var(--muted); font-weight:400;">(optional)</span></label>
                <textarea name="Description" class="form-control" rows="3"></textarea>
            </div>

            <div style="display:flex; gap:10px;">
                <button type="submit" class="btn btn-primary"><i class="fas fa-save"></i> Book Appointment</button>
                <a href="/Admin/Appointments" class="btn btn-outline">Cancel</a>
            </div>
        </form>
    </div>
</div>
