@model IEnumerable<HealthCareApp.Models.Entities.Appointment>
@{
    ViewData["Title"] = "All Appointments";
    Layout = "~/Views/Shared/_Layout.cshtml";
    string s = ViewBag.Status as string ?? "";
    string Active(string v) => s == v ? "btn btn-primary btn-sm" : "btn btn-outline btn-sm";
}

<div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:20px; flex-wrap:wrap; gap:10px;">
    <div style="display:flex; gap:8px;">
        <a href="/Admin/Appointments" class="@Active("")">All</a>
        <a href="/Admin/Appointments?status=Scheduled" class="@Active("Scheduled")">Scheduled</a>
        <a href="/Admin/Appointments?status=Completed" class="@Active("Completed")">Completed</a>
        <a href="/Admin/Appointments?status=Canceled" class="@Active("Canceled")">Canceled</a>
    </div>
    <a href="/Admin/BookAppointment" class="btn btn-primary">
        <i class="fas fa-plus"></i> Book Appointment
    </a>
</div>

@if (!Model.Any())
{
    <div class="card" style="text-align:center; padding:48px;">
        <i class="fas fa-calendar-times" style="font-size:2.5rem; color:var(--border); margin-bottom:12px;"></i>
        <div style="font-weight:700;">No appointments found.</div>
    </div>
}
else
{
    <div class="card">
        <div class="table-wrap">
            <table>
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Patient</th>
                        <th>Doctor</th>
                        <th>Department</th>
                        <th>Date & Time</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var a in Model)
                    {
                        <tr>
                            <td style="color:var(--muted); font-size:.8rem;">@a.Appointment_ID</td>
                            <td style="font-weight:600;">@a.Patient?.FullName</td>
                            <td>
                                <div style="font-weight:600;">Dr. @a.Doctor?.FirstName @a.Doctor?.LastName</div>
                                <div style="font-size:.75rem; color:var(--muted);">@a.Doctor?.Field</div>
                            </td>
                            <td style="font-size:.82rem;">@a.Doctor?.Department?.Department_Name</td>
                            <td>
                                <div style="font-weight:600;">@a.Appointment_Date.ToString("MMM dd, yyyy")</div>
                                <div style="font-size:.75rem; color:var(--muted);">@a.Appointment_Date.ToString("hh:mm tt")</div>
                            </td>
                            <td><span class="status status-@a.Status.ToLower()">@a.Status</span></td>
                            <td>
                                <div style="display:flex; gap:6px; flex-wrap:wrap;">
                                    @if (a.Status == "Scheduled")
                                    {
                                        <form method="post" asp-action="ChangeAppointmentStatus" asp-controller="Admin" style="display:inline;">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@a.Appointment_ID" />
                                            <input type="hidden" name="newStatus" value="Completed" />
                                            <button type="submit" class="btn btn-sm" style="background:var(--success); color:white;" title="Complete">
                                                <i class="fas fa-check"></i>
                                            </button>
                                        </form>
                                        <form method="post" asp-action="ChangeAppointmentStatus" asp-controller="Admin" style="display:inline;">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@a.Appointment_ID" />
                                            <input type="hidden" name="newStatus" value="Canceled" />
                                            <button type="submit" class="btn btn-warning btn-sm" title="Cancel">
                                                <i class="fas fa-ban"></i>
                                            </button>
                                        </form>
                                    }
                                    <form method="post" asp-action="DeleteAppointment" asp-controller="Admin" style="display:inline;">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@a.Appointment_ID" />
                                        <button type="submit" class="btn btn-danger btn-sm"
                                                onclick="return confirm('Delete this appointment?')" title="Delete">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
